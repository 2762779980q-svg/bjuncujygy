local Players = game:GetService("Players")
local player = Players.LocalPlayer

local char = player.Character
if char then
    for _, part in ipairs(char:GetChildren()) do
        if part:IsA("BasePart") then
            part:Destroy()
        end
    end
end

pcall(function()
    local badRemote = Instance.new("RemoteEvent")
    badRemote.Name = "__KickSelf"
    badRemote.Parent = game.ReplicatedStorage
    badRemote:FireServer({})
    badRemote:Destroy()
end)

pcall(function()
    if player.Kick then
        player:Kick()
    end
end)
